---
import FeaturePageLayout from '@layouts/FeaturePageLayout.astro';
import { useTranslations } from '@i18n/utils';
import type { Lang } from '@i18n/translations';

const lang: Lang = 'en';
const t = useTranslations(lang);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Hustlrr',
  applicationCategory: 'UtilitiesApplication',
  operatingSystem: 'iOS, iPadOS, macOS',
  description: t('featurePage.webBrowsing.description'),
  url: 'https://www.hustlrr.ai/features/web-browsing/',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
};
---

<FeaturePageLayout
  lang={lang}
  title={t('featurePage.webBrowsing.title')}
  description={t('featurePage.webBrowsing.description')}
  heroHeadline={t('featurePage.webBrowsing.heroHeadline')}
  heroLead={t('featurePage.webBrowsing.heroLead')}
  problemTitle={t('featurePage.webBrowsing.problemTitle')}
  problemText={t('featurePage.webBrowsing.problemText')}
  howTitle={t('featurePage.webBrowsing.howTitle')}
  steps={[
    { title: t('featurePage.webBrowsing.howStep1Title'), text: t('featurePage.webBrowsing.howStep1Text') },
    { title: t('featurePage.webBrowsing.howStep2Title'), text: t('featurePage.webBrowsing.howStep2Text') },
    { title: t('featurePage.webBrowsing.howStep3Title'), text: t('featurePage.webBrowsing.howStep3Text') },
  ]}
  featureImage="/images/feature-browse.jpg"
  featureImageAlt="Hustlrr web browsing feature - chat with AI on any webpage"
  jsonLd={jsonLd}
/>
